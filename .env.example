APP_NAME=Larafeed
APP_ENV=development
APP_URL=http://localhost:3333
PORT=3000

DATABASE_URL=postgres://localhost:5432/larafeed?sslmode=disable
SESSION_SECRET=change-me-to-a-32-byte-secret!!

# Vite dev server (for hot reload in development)
VITE_DEV_URL=http://localhost:5173

# Feature flags
REGISTRATION_ENABLED=true

# ImgProxy (optional)
IMGPROXY_URL=
IMGPROXY_KEY=
IMGPROXY_SALT=

# Gemini (optional, for LLM features)
GEMINI_API_KEY=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Mail (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=hello@example.com
