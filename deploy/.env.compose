APP_NAME=Larafeed
APP_URL=http://localhost:8000
APP_ENV=production
PORT=3000

DATABASE_URL=postgres://larafeed:larafeed@postgres:5432/larafeed?sslmode=disable

IMGPROXY_URL=http://imgproxy:8080

# Optional: Gemini API key for AI summaries
# GEMINI_API_KEY=

# Optional: Telegram notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=hello@example.com

# Optional: Registration toggle
REGISTRATION_ENABLED=true
